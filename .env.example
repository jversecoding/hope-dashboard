# 이 파일을 복사해서 .env로 저장하고 실제 값을 채우세요 (.env는 git에 커밋되지 않습니다).
# 로컬 실행: node --env-file=.env server.js
# Vercel 배포: 아래 3개 값을 Vercel 프로젝트 Settings > Environment Variables에 동일하게 등록하세요.

# https://www.kobis.or.kr/kobisopenapi 에서 발급
KOBIS_API_KEY=

# https://developers.naver.com/apps/#/register 에서 발급 (사용 API: 검색)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
